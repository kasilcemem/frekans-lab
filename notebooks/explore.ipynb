   "source": [
    "# FreqLab — Frekans Analizi Denemeleri\n",
    "\n",
    "Bu notebook FreqLab modüllerini interaktif olarak test etmek için hazırlanmıştır."
   ],
   "id": "cell-md-01"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../src')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from analyzer import analiz_et, fft_hesapla, dominant_frekanslar\n",
    "from visualizer import spektrum_ciz, dalga_formu_ciz, spektrogram_ciz, bant_grafigi_ciz\n",
    "from audio_input import dosya_oku\n",
    "from utils import nota_bul, normalize, bant_geciren_filtre\n",
    "\n",
    "print('Modüller yüklendi.')"
   ],
   "id": "cell-code-01"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Saf sinüs sinyali üret ve analiz et"
   ],
   "id": "cell-md-02"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SAMPLE_RATE = 44100\n",
    "SURE = 2.0\n",
    "FREKANS = 440.0\n",
    "\n",
    "t = np.linspace(0, SURE, int(SAMPLE_RATE * SURE), endpoint=False)\n",
    "sinyal = np.sin(2 * np.pi * FREKANS * t).astype(np.float32)\n",
    "\n",
    "print(f'Sinyal üretildi: {FREKANS} Hz, {SURE} saniye, {len(sinyal)} örnek')"
   ],
   "id": "cell-code-02"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Dalga formu"
   ],
   "id": "cell-md-03"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dalga_formu_ciz(sinyal, SAMPLE_RATE)"
   ],
   "id": "cell-code-03"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. FFT spektrum"
   ],
   "id": "cell-md-04"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "frekanslar, genlikler = fft_hesapla(sinyal, SAMPLE_RATE)\n",
    "spektrum_ciz(frekanslar, genlikler)"
   ],
   "id": "cell-code-05"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Dominant frekanslar"
   ],
   "id": "cell-md-06"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sonuclar = dominant_frekanslar(frekanslar, genlikler, top_n=5)\n",
    "print('Dominant frekanslar:')\n",
    "for s in sonuclar:\n",
    "    nota = nota_bul(s['frekans'])\n",
    "    print(f\"  {s['frekans']} Hz → {nota} — genlik: {s['genlik']}\")"
   ],
   "id": "cell-code-06"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Bant güç analizi"
   ],
   "id": "cell-md-07"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sonuc = analiz_et(sinyal, SAMPLE_RATE)\n",
    "print('Bant güçleri:')\n",
    "for bant, guc in sonuc['bantlar'].items():\n",
    "    print(f'  {bant}: {guc}')\n",
    "\n",
    "bant_grafigi_ciz(sonuc['bantlar'])"
   ],
   "id": "cell-code-07"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Bant geçiren filtre uygula"
   ],
   "id": "cell-md-08"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "karisik = (\n",
    "    np.sin(2 * np.pi * 100 * t) +\n",
    "    np.sin(2 * np.pi * 440 * t) +\n",
    "    np.sin(2 * np.pi * 8000 * t)\n",
    ").astype(np.float32)\n",
    "\n",
    "filtrelenmis = bant_geciren_filtre(karisik, 200, 2000, SAMPLE_RATE)\n",
    "\n",
    "fig, axs = plt.subplots(2, 1, figsize=(12, 6))\n",
    "axs[0].plot(t[:2000], karisik[:2000], color='#378ADD', linewidth=0.6)\n",
    "axs[0].set_title('Orijinal sinyal (100 + 440 + 8000 Hz)')\n",
    "axs[1].plot(t[:2000], filtrelenmis[:2000], color='#1D9E75', linewidth=0.6)\n",
    "axs[1].set_title('Filtre sonrası (200–2000 Hz bant geçiren)')\n",
    "for ax in axs:\n",
    "    ax.set_xlabel('Zaman (sn)')\n",
    "    ax.set_ylabel('Genlik')\n",
    "    ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "cell-code-08"
  },
